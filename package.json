{
  "name": "mcp-delve-think-tool",
  "version": "1.0.0",
  "description": "DELVE — the think tool that makes AI agents question their own assumptions. Premise-tracked reasoning with contradiction detection and stability scoring.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-delve-think-tool": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "mcp-use dev",
    "build": "mcp-use build",
    "start": "mcp-use start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "inspect": "npx @mcp-use/inspector --url http://localhost:3001/mcp"
  },
  "keywords": [
    "mcp",
    "reasoning",
    "structured-thinking",
    "think-tool",
    "epistemic",
    "premise-tracking",
    "contradiction-detection",
    "ai",
    "model-context-protocol",
    "delve",
    "agent-reasoning",
    "chain-of-thought"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yigitkonur/mcp-delve-think-tool.git"
  },
  "homepage": "https://think.yigitkonur.com",
  "bugs": {
    "url": "https://github.com/yigitkonur/mcp-delve-think-tool/issues"
  },
  "author": "Yigit Konur",
  "license": "MIT",
  "dependencies": {
    "mcp-use": "1.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mcp-use/cli": "2.20.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
